# ─── App (Next.js) ───────────────────────────────────────
# Public variables are exposed to the browser. Prefix with NEXT_PUBLIC_.
# Private variables are only available in Node.js (server-side) at build time.

# Next.js public URL (used for API calls from the browser)
# Required in production; localhost values are rejected by the production build.
NEXT_PUBLIC_API_URL=http://localhost:5000

# API base URL for server-side requests (internal Docker network)
API_INTERNAL_URL=http://api:5000

# ─── App Configuration ──────────────────────────────────
NEXT_PUBLIC_APP_NAME=DocuMind AI
NEXT_PUBLIC_APP_URL=http://localhost:3000
