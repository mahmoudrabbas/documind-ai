# ─── Workers Service ─────────────────────────────────────
NODE_ENV=development

# ─── Database ────────────────────────────────────────────
# Production and test modes require an explicit URI or MONGODB_URI_FILE.
MONGODB_URI=mongodb://mongodb:27017/docsai

# ─── Cache ───────────────────────────────────────────────
# Production and test modes require an explicit URL or REDIS_URL_FILE.
REDIS_URL=redis://redis:6379

# ─── Worker Configuration ────────────────────────────────
WORKER_CONCURRENCY=1

# ─── Logging ─────────────────────────────────────────────
LOG_LEVEL=info
