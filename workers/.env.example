# ─── Workers Service ─────────────────────────────────────
NODE_ENV=development

# ─── Database ────────────────────────────────────────────
MONGODB_URI=mongodb://mongodb:27017/docsai

# ─── Cache ───────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── Worker Configuration ────────────────────────────────
WORKER_CONCURRENCY=1

# ─── Logging ─────────────────────────────────────────────
LOG_LEVEL=info
</write_to_file>