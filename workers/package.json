{
  "name": "workers",
  "version": "1.0.0",
  "private": true,
  "description": "DocuMind AI background workers — document processing, embeddings, and queue consumers.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "prebuild": "npm run build --workspace=@documind/contracts",
    "build": "tsc",
    "start": "node dist/index.js",
    "pretypecheck": "npm run build --workspace=@documind/contracts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "pretest": "npm run build --workspace=@documind/contracts",
    "test": "find src -name '*.test.ts' -print0 | xargs -0 -r -n 1 node --import tsx --test"
  },
  "dependencies": {
    "@documind/contracts": "*",
    "bullmq": "^5.80.5",
    "dotenv": "^17.4.2",
    "ioredis": "^5.11.1",
    "mongodb": "^6.21.0",
    "pino": "^10.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3"
  }
}
