# ─── Server ──────────────────────────────────────────────
NODE_ENV=development
PORT=5000
HOST=0.0.0.0

# ─── Database ────────────────────────────────────────────
MONGODB_URI=mongodb://mongodb:27017/docsai
MONGODB_MAX_RETRIES=5
MONGODB_RETRY_DELAY_MS=1000
MONGODB_RETRY_BACKOFF_FACTOR=2
MONGODB_RETRY_MAX_DELAY_MS=10000

# ─── Cache ───────────────────────────────────────────────
# Local dev (docker-compose): redis://redis:6379
# Production (Railway): set REDIS_URL in Railway's dashboard to your Upstash rediss:// URL
REDIS_URL=redis://redis:6379

# ─── URLs / Auth ─────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000
APP_FRONTEND_URL=http://localhost:3000
JWT_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=7d

# One-time platform administrator bootstrap. Enable temporarily, then disable and remove the key.
ENABLE_SUPER_ADMIN_BOOTSTRAP=false
SUPER_ADMIN_BOOTSTRAP_KEY=

# ─── Email Verification ─────────────────────────────────
EMAIL_VERIFICATION_JWT_SECRET=
EMAIL_VERIFICATION_JWT_EXPIRES_IN=24h
PASSWORD_RESET_JWT_SECRET=
PASSWORD_RESET_JWT_EXPIRES_IN=15m

# ─── Email Sending ───────────────────────────────────────
SEND_EMAILS=false
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=
SMTP_FROM="DocuMind AI <no-reply@example.com>"

# ─── File Uploads / Storage ───────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_BYTES=52428800
ALLOWED_MIME_TYPES=application/pdf,text/plain,text/markdown,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/msword

# ─── Payment Provider ───────────────────────────────────
# Set to "stripe" for production, "fake" for development/test
PAYMENT_PROVIDER=fake
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# ─── Logging ─────────────────────────────────────────────
LOG_LEVEL=info
LOG_PRETTY=false

SEED_SUPER_ADMIN_ENABLED=false
SEED_PLATFORM_TENANT_NAME=DocuMind AI
SEED_PLATFORM_TENANT_SLUG=documind-ai
SEED_SUPER_ADMIN_NAME=DocuMind Platform Admin
SEED_SUPER_ADMIN_EMAIL=
SEED_SUPER_ADMIN_PASSWORD=

# ─── OCR Provider ────────────────────────────────────────
# Provider selection: "fake" (testing), "tesseract" (local), "paddle" (PaddleOCR service)
OCR_PROVIDER=fake
# Fallback provider used when primary fails after all retries
OCR_FALLBACK_PROVIDER=fake
# Per-page OCR timeout in milliseconds
OCR_TIMEOUT=30000
# Max retry attempts per provider before falling back
OCR_MAX_RETRIES=3
# Delay between retries in milliseconds (multiplied by attempt number)
OCR_RETRY_DELAY_MS=1000
# Confidence thresholds for quality gating (0-1 scale)
OCR_CONFIDENCE_THRESHOLD=0.7
OCR_CRITICAL_CONFIDENCE_THRESHOLD=0.4
# Maximum pages per OCR job
OCR_MAX_PAGES=500
# Maximum file size for OCR input in bytes (50 MB default)
OCR_MAX_FILE_SIZE_BYTES=52428800
# OCR service URL (only needed when OCR_PROVIDER=ocr)
OCR_SERVICE_URL=http://localhost:8501
