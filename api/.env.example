# ─── Server ──────────────────────────────────────────────
NODE_ENV=development
PORT=5000
HOST=0.0.0.0

# ─── Database ────────────────────────────────────────────
MONGODB_URI=mongodb://mongodb:27017/docsai
MONGODB_MAX_RETRIES=5
MONGODB_RETRY_DELAY_MS=1000
MONGODB_RETRY_BACKOFF_FACTOR=2
MONGODB_RETRY_MAX_DELAY_MS=10000

# ─── Cache ───────────────────────────────────────────────
# Local dev (docker-compose): redis://redis:6379
# Production (Railway): set REDIS_URL in Railway's dashboard to your Upstash rediss:// URL
REDIS_URL=redis://redis:6379

# ─── URLs / Auth ─────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000
APP_FRONTEND_URL=http://localhost:3000
JWT_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=7d

# One-time platform administrator bootstrap. Enable temporarily, then disable and remove the key.
ENABLE_SUPER_ADMIN_BOOTSTRAP=false
SUPER_ADMIN_BOOTSTRAP_KEY=

# ─── Email Verification ─────────────────────────────────
EMAIL_VERIFICATION_JWT_SECRET=
EMAIL_VERIFICATION_JWT_EXPIRES_IN=24h
PASSWORD_RESET_JWT_SECRET=
PASSWORD_RESET_JWT_EXPIRES_IN=15m

# ─── Email Sending ───────────────────────────────────────
SEND_EMAILS=false
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=
SMTP_FROM="DocuMind AI <no-reply@example.com>"

# ─── File Uploads / Storage ───────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_BYTES=52428800
ALLOWED_MIME_TYPES=application/pdf,text/plain,text/markdown,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/msword

# ─── Logging ─────────────────────────────────────────────
LOG_LEVEL=info
LOG_PRETTY=false

SEED_SUPER_ADMIN_ENABLED=false
SEED_PLATFORM_TENANT_NAME=DocuMind AI
SEED_PLATFORM_TENANT_SLUG=documind-ai
SEED_SUPER_ADMIN_NAME=DocuMind Platform Admin
SEED_SUPER_ADMIN_EMAIL=
SEED_SUPER_ADMIN_PASSWORD=
