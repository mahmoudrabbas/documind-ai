# ─── Server ──────────────────────────────────────────────
NODE_ENV=development
PORT=5000
HOST=0.0.0.0

# ─── Database ────────────────────────────────────────────
MONGODB_URI=mongodb://mongodb:27017/docsai

# ─── Cache ───────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── URLs / Auth ─────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000
APP_FRONTEND_URL=http://localhost:3000
JWT_SECRET=
JWT_EXPIRES_IN=7d

# ─── Email Verification ─────────────────────────────────
EMAIL_VERIFICATION_JWT_SECRET=
EMAIL_VERIFICATION_JWT_EXPIRES_IN=24h

# ─── Email Sending ───────────────────────────────────────
SEND_EMAILS=false
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ─── Logging ─────────────────────────────────────────────
LOG_LEVEL=info
